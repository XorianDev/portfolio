<section class="bg-neutral-primary scroll-mt-16 py-8" id="contact">
  <span class="flex justify-center mb-10 text-gray-900 dark:text-white">
    <h2 class="text-3xl font-semibold">Contact</h2>
  </span>

  <form
    autocomplete="off"
    class="max-w-md mx-auto"
    id="contact-form"
    novalidate
  >
    <input
      autocomplete="off"
      name="company"
      style="position:absolute; left:-9999px;"
      tabindex="-1"
      type="text"
    />

    <div class="grid md:grid-cols-2 md:gap-6">
      <div class="relative z-0 w-full mb-5 group">
        <input
          class="block py-2.5 px-0 w-full text-sm text-heading bg-transparent
          border-0 border-b-2 border-default-medium appearance-none
          focus:outline-none focus:ring-0 focus:border-brand peer"
          id="floating_first_name"
          name="floating_first_name"
          placeholder=" "
          required
          type="text"
        />
        <label
          class="absolute text-sm text-body duration-300 transform
          -translate-y-6 scale-75 top-3 -z-10 origin-[0]
          peer-focus:text-fg-brand
          peer-placeholder-shown:scale-100
          peer-placeholder-shown:translate-y-0
          peer-focus:scale-75 peer-focus:-translate-y-6"            for="floating_first_name"
        >
          First name
        </label>
      </div>

      <div class="relative z-0 w-full mb-5 group">
        <input
          class="block py-2.5 px-0 w-full text-sm text-heading bg-transparent
          border-0 border-b-2 border-default-medium appearance-none
          focus:outline-none focus:ring-0 focus:border-brand peer"
          id="floating_last_name"
          name="floating_last_name"
          placeholder=" "
          required
          type="text"
        />
        <label
          class="absolute text-sm text-body duration-300 transform
          -translate-y-6 scale-75 top-3 -z-10 origin-[0]
          peer-focus:text-fg-brand
          peer-placeholder-shown:scale-100
          peer-placeholder-shown:translate-y-0
          peer-focus:scale-75 peer-focus:-translate-y-6"            for="floating_last_name"
        >
          Last name
        </label>
      </div>
    </div>

    <div class="relative z-0 w-full mb-5 group">
      <input
        class="block py-2.5 px-0 w-full text-sm text-heading bg-transparent
        border-0 border-b-2 border-default-medium appearance-none
        focus:outline-none focus:ring-0 focus:border-brand peer"
        id="floating_email"
        name="floating_email"
        placeholder=" "
        required
        type="email"
      />
      <label
        class="absolute text-sm text-body duration-300 transform
        -translate-y-6 scale-75 top-3 -z-10 origin-[0]
        peer-focus:text-fg-brand
        peer-placeholder-shown:scale-100
        peer-placeholder-shown:translate-y-0
        peer-focus:scale-75 peer-focus:-translate-y-6"          for="floating_email"
      >
        Email address
      </label>
    </div>

    <div class="relative z-0 w-full mb-5 group">
      <input
        class="block py-2.5 px-0 w-full text-sm text-heading bg-transparent
        border-0 border-b-2 border-default-medium appearance-none
        focus:outline-none focus:ring-0 focus:border-brand peer"
        id="subject"
        name="subject"
        placeholder=" "
        required
        type="text"
      />
      <label
        class="absolute text-sm text-body duration-300 transform
        -translate-y-6 scale-75 top-3 -z-10 origin-[0]
        peer-focus:text-fg-brand
        peer-placeholder-shown:scale-100
        peer-placeholder-shown:translate-y-0
        peer-focus:scale-75 peer-focus:-translate-y-6"          for="subject"
      >
        Subject
      </label>
    </div>

    <div class="relative z-0 w-full mb-5 group">
      <textarea
        class="block py-2.5 px-0 w-full text-sm text-heading bg-transparent
        border-0 border-b-2 border-default-medium appearance-none
        focus:outline-none focus:ring-0 focus:border-brand peer"
        id="floating_message"
        name="floating_message"
        placeholder=" "
        required
        rows="4"
      ></textarea>
      <label
        class="absolute text-sm text-body duration-300 transform
        -translate-y-6 scale-75 top-3 -z-10 origin-[0]
        peer-focus:text-fg-brand
        peer-placeholder-shown:scale-100
        peer-placeholder-shown:translate-y-0
        peer-focus:scale-75 peer-focus:-translate-y-6"          for="floating_message"
      >
        Message
      </label>
    </div>

    <p
      class="hidden text-sm text-red-600 mb-4 text-center"
      id="form-error"
    ></p>

    <p
      class="hidden text-sm text-green-600 mb-4 text-center"
      id="form-success"
    >
      Your message has been sent successfully. I’ll get back to you soon.
    </p>

    <div class="flex justify-center">
    <button
      class="text-white bg-brand box-border border border-transparent
      hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium
      shadow-xs font-medium leading-5 rounded-base text-sm
      px-4 py-2.5 focus:outline-none disabled:opacity-60 disabled:cursor-not-allowed"
      id="submit-button" type="submit"
    >
      <span id="submit-text">Submit</span>
    </button>
    </div>
  </form>
</section>
